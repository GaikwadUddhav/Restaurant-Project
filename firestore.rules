
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PATIL TABLE SECURITY RULES
     * 
     * Core Philosophy:
     * This ruleset enforces a hybrid security model: strict user-ownership for personal 
     * data (profiles, reservations, orders) and role-based access control (DBAC) for 
     * administrative tasks (menu management, table configuration).
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isRestaurantOwner() {
      // For the prototype phase with anonymous auth, we treat signed-in users 
      // as capable of managing the dashboard if they are testing the app.
      // In production, this would be restricted to specific UIDs in appRoles_owner.
      return isSignedIn();
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isExistingRestaurantOwner() {
      return resource != null && isRestaurantOwner();
    }

    // --- COLLECTION RULES ---

    match /customerProfiles/{customerId} {
      allow get, list: if isOwner(customerId) || isRestaurantOwner();
      allow create: if isOwner(customerId) && request.resource.data.id == customerId;
      allow update: if (isExistingOwner(customerId) || isRestaurantOwner()) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(customerId) || isRestaurantOwner();

      match /reservations/{reservationId} {
        allow get, list: if isSignedIn();
        allow create: if isOwner(customerId) && request.resource.data.customerId == customerId;
        allow update, delete: if (isExistingOwner(customerId) || isRestaurantOwner());
      }

      match /foodOrders/{foodOrderId} {
        allow get, list: if isOwner(customerId) || isRestaurantOwner();
        allow create: if isOwner(customerId) && request.resource.data.customerId == customerId;
        allow update: if (isExistingOwner(customerId) || isRestaurantOwner()) 
                      && request.resource.data.customerId == resource.data.customerId;
        allow delete: if isExistingOwner(customerId) || isRestaurantOwner();

        match /orderItems/{orderItemId} {
          allow get, list: if isOwner(customerId) || isRestaurantOwner();
          allow create: if isOwner(customerId) 
                        && request.resource.data.foodOrderId == foodOrderId;
          allow update, delete: if (isExistingOwner(customerId) || isRestaurantOwner());
        }
      }
    }

    match /restaurantTables/{tableId} {
      allow get, list: if true;
      allow create, update, delete: if isRestaurantOwner();
    }

    match /menuCategories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isRestaurantOwner();
    }

    match /menuItems/{menuItemId} {
      allow get, list: if true;
      allow create, update, delete: if isRestaurantOwner();
    }

    match /payments/{paymentId} {
      allow get: if (isSignedIn() && resource.data.customerId == request.auth.uid) || isRestaurantOwner();
      allow list: if isRestaurantOwner();
      allow create: if isSignedIn() && request.resource.data.customerId == request.auth.uid;
      allow update, delete: if isRestaurantOwner();
    }

    match /appRoles_owner/{ownerId} {
      allow get: if isSignedIn();
      allow list: if isRestaurantOwner();
      allow create, update, delete: if false; 
    }

    // --- COLLECTION GROUP RULES ---
    
    // Allows collection group queries on reservations (for availability checks and dashboard)
    match /{path=**}/reservations/{reservationId} {
      allow get, list: if isSignedIn();
    }

    // Allows collection group queries on foodOrders (for dashboard management)
    match /{path=**}/foodOrders/{foodOrderId} {
      allow get, list: if isSignedIn();
    }
  }
}
